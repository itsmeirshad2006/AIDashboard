# ─────────────────────────────────────────────────────────────
# AI Models Intelligence Dashboard — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# Required: Google Gemini API key, used ONLY server-side by the
# /api/recommend route. Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the Gemini model used for recommendations.
# Defaults to "gemini-2.0-flash" if unset.
GEMINI_MODEL=gemini-2.0-flash
